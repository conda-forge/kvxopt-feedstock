diff --git a/src/C/dense.c b/src/C/dense.c
index 959eaf5..a1b2c3d 100644
--- a/src/C/dense.c
+++ b/src/C/dense.c
@@ -158,7 +158,11 @@ matrix * Matrix_New(int nrows, int ncols, int id)
     return NULL;
   }
 
-  a->id = id; a->nrows = nrows; a->ncols = ncols;
+  a->id = id; a->nrows = nrows; a->ncols = ncols;
