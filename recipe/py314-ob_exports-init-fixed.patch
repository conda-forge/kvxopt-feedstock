@@ -1398,7 +1408,8 @@ matrix_buffer_getbuf(matrix *self, Py_buffer *view, int flags)
   self->shape[0] = self->nrows; self->shape[1] = self->ncols;
   view->shape = self->shape;
 
   view->obj = (PyObject*)self;
   view->internal = NULL;
 
   Py_INCREF(self);
   self->ob_exports++;
 
   return 0;
 }
 
